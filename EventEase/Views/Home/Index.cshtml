@{
    ViewData["Title"] = "Home";
}
<style>
    body {
        background-color: #A67C52;
        background-size: cover;
        background-attachment: fixed;
        background-position: center;
    }

    .card {
        background-color: white (255, 255, 255, 0.85);
        backdrop-filter: blur(5px);
    }
 .btn-brown {
        background-color: #A67C52;
        color: white;
        border: none;
    }

        .btn-brown:hover {
            background-color: #8B6343;
            color: white;
        }
</style>

<!-- Quick Access Cards -->
<div class="row row-cols-1 row-cols-md-2 g-4 mb-4">
    <div class="col">
        <div class="card h-100 shadow">
            <img src="https://placehold.co/600x200?text=Venues" class="card-img-top" alt="Venues"/>
            <div class="card-body">
                <h5 class="card-title"> Venues</h5>
                <p class="card-text">Browse and manage all available venues for your events.</p>
                <a asp-controller="Venues" asp-action="Index" class="btn btn-brown">View Venues</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 shadow">
            <img src="https://placehold.co/600x200?text=Events" class="card-img-top" alt="Events"/>
            <div class="card-body">
                <h5 class="card-title"> Events</h5>
                <p class="card-text">Discover and manage upcoming events happening near you.</p>
                <a asp-controller="Events" asp-action="Index" class="btn btn-brown">View Events</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 shadow">
            <img src="https://placehold.co/600x200?text=Customers" class="card-img-top" alt="Customers"/>
            <div class="card-body">
                <h5 class="card-title">Customers</h5>
                <p class="card-text">Manage your customer base and their information.</p>
                <a asp-controller="Customers" asp-action="Index" class="btn btn-brown">View Customers</a>
            </div>
        </div>
    </div>
    <div class="col">
        <div class="card h-100 shadow">
            <img src="https://placehold.co/600x200?text=Bookings" class="card-img-top" alt="Bookings"/>
            <div class="card-body">
                <h5 class="card-title">Bookings</h5>
                <p class="card-text">Track and manage all event bookings and reservations.</p>
                <a asp-controller="Bookings" asp-action="Index" class="btn btn-brown">View Bookings</a>
            </div>
        </div>
    </div>
</div>